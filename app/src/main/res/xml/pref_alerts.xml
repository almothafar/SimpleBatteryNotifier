<!-- The "Alerts" screen (#112): WHAT to be notified about. One category per alert event, in
     battery-lifecycle order (levels → warning → critical → full → temperature → drain → charging).
     Cross-cutting delivery options (sound in silent mode, vibration, quiet hours, stickiness)
     live on the "Notification behaviour" screen (pref_behaviour.xml). -->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- The slider configures the warning + critical alerts directly below it -->
    <PreferenceCategory
        android:title="@string/pref_cat_title_thresholds"
        app:iconSpaceReserved="false">

        <com.almothafar.simplebatterynotifier.ui.preference.BatteryRangeSliderPreference
            android:key="@string/_pref_key_battery_level_range"
            android:persistent="false"
            app:criticalKey="@string/_pref_key_critical_battery_level"
            app:warningKey="@string/_pref_key_warn_battery_level"
            app:sliderFrom="10"
            app:sliderTo="50"
            app:sliderMinSeparation="5"
            app:criticalDefault="20"
            app:warningDefault="40"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_warning"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/_pref_key_notify_for_warning_level"
            android:summaryOff="@string/notify_for_warning_level_summary_off"
            android:summaryOn="@string/notify_for_warning_level_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/notify_for_warning_level"
            app:iconSpaceReserved="false" />

        <com.almothafar.simplebatterynotifier.ui.preference.RingtonePreference
            android:defaultValue="content://settings/system/notification_sound"
            android:dependency="@string/_pref_key_notify_for_warning_level"
            android:key="@string/_pref_key_notifications_warning_sound_ringtone"
            android:ringtoneType="notification"
            android:title="@string/notifications_warning_sound_ringtone"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_critical"
        app:iconSpaceReserved="false">

        <com.almothafar.simplebatterynotifier.ui.preference.RingtonePreference
            android:defaultValue="content://settings/system/notification_sound"
            android:key="@string/_pref_key_notifications_alert_sound_ringtone"
            android:ringtoneType="notification"
            android:title="@string/notifications_alert_sound_ringtone"
            app:iconSpaceReserved="false" />

        <SwitchPreference
            android:defaultValue="false"
            android:key="@string/_pref_key_notify_every_tick"
            android:summaryOff="@string/notify_every_tick_summary_off"
            android:summaryOn="@string/notify_every_tick_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/notify_every_tick"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_full_battery"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/_pref_key_notify_for_full_level"
            android:summaryOff="@string/notify_for_full_level_summary_off"
            android:summaryOn="@string/notify_for_full_level_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/notify_for_full_level"
            app:iconSpaceReserved="false" />

        <com.almothafar.simplebatterynotifier.ui.preference.RingtonePreference
            android:defaultValue="content://settings/system/notification_sound"
            android:dependency="@string/_pref_key_notify_for_full_level"
            android:key="@string/_pref_key_notifications_full_sound_ringtone"
            android:ringtoneType="notification"
            android:title="@string/notifications_full_sound_ringtone"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_temperature"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/_pref_key_notify_high_temperature"
            android:summaryOff="@string/notify_high_temperature_summary_off"
            android:summaryOn="@string/notify_high_temperature_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/notify_high_temperature"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            android:defaultValue="45"
            android:dependency="@string/_pref_key_notify_high_temperature"
            android:key="@string/_pref_key_high_temperature_threshold"
            android:min="40"
            android:max="60"
            android:title="@string/high_temperature_threshold"
            style="@style/PreferenceSeekBar"
            app:showSeekBarValue="true"
            app:adjustable="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_drain"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/_pref_key_notify_fast_drain"
            android:summaryOff="@string/notify_fast_drain_summary_off"
            android:summaryOn="@string/notify_fast_drain_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/notify_fast_drain"
            app:iconSpaceReserved="false" />

        <!-- Shared with #108's table colouring, so it is NOT gated by the alert toggle above.
             defaultValue/min/max must match BatteryRateTracker.DEFAULT/MIN/MAX_DRAIN_LIMIT_PPH,
             which clamp the stored value when it is read (#108/#109). -->
        <SeekBarPreference
            android:defaultValue="20"
            android:key="@string/_pref_key_fast_drain_limit"
            android:min="5"
            android:max="60"
            android:summary="@string/drain_limit_summary"
            android:title="@string/drain_limit"
            style="@style/PreferenceSeekBar"
            app:showSeekBarValue="true"
            app:adjustable="true"
            app:iconSpaceReserved="false" />

        <!-- defaultValue/min/max of both timing sliders must match FastDrainDetector's
             DEFAULT/MIN/MAX_SUSTAINED_MINUTES and DEFAULT/MIN/MAX_REMINDER_MINUTES, which clamp
             the stored values when they are read (#109). -->
        <SeekBarPreference
            android:defaultValue="5"
            android:dependency="@string/_pref_key_notify_fast_drain"
            android:key="@string/_pref_key_fast_drain_sustained_minutes"
            android:min="1"
            android:max="30"
            android:title="@string/fast_drain_sustained_minutes"
            style="@style/PreferenceSeekBar"
            app:showSeekBarValue="true"
            app:adjustable="true"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            android:defaultValue="15"
            android:dependency="@string/_pref_key_notify_fast_drain"
            android:key="@string/_pref_key_fast_drain_reminder_minutes"
            android:min="5"
            android:max="60"
            android:title="@string/fast_drain_reminder_minutes"
            style="@style/PreferenceSeekBar"
            app:showSeekBarValue="true"
            app:adjustable="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Charging announcements (#122/#127). Future charging alerts (e.g. #123 slow-charge
         warning) belong in this category too. -->
    <PreferenceCategory
        android:title="@string/pref_cat_title_charging"
        app:iconSpaceReserved="false">

        <ListPreference
            android:defaultValue="@string/_pref_value_charge_notification_style_toast"
            android:entries="@array/charge_notification_style_entries"
            android:entryValues="@array/charge_notification_style_values"
            android:key="@string/_pref_key_charge_notification_style"
            android:title="@string/charge_notification_style_title"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
