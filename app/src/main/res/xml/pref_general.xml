<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/pref_language_category"
        app:iconSpaceReserved="false">

        <ListPreference
            android:key="@string/_pref_key_language"
            android:persistent="false"
            android:entries="@array/language_entries"
            android:entryValues="@array/language_values"
            android:title="@string/pref_title_language"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_cat_title_display"
        app:iconSpaceReserved="false">

        <ListPreference
            android:defaultValue="@string/_pref_value_temperatures_unit_c"
            android:entries="@array/preference_list_temperatures"
            android:entryValues="@array/preference_list_temperatures_values"
            android:key="@string/_pref_key_temperatures_unit"
            android:summary="%s"
            android:title="@string/preference_title_temperature"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- The ongoing status notification's content — not an alert, so it lives here (#112) -->
    <PreferenceCategory
        android:title="@string/pref_cat_title_status_notification"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:defaultValue="true"
            android:key="@string/_pref_key_show_rate_in_notification"
            android:summaryOff="@string/show_rate_in_notification_summary_off"
            android:summaryOn="@string/show_rate_in_notification_summary_on"
            android:switchTextOff="@string/off"
            android:switchTextOn="@string/on"
            android:title="@string/show_rate_in_notification"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
