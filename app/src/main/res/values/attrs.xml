<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="HorseshoeProgressBar">
        <attr name="gaugeStrokeWidth" format="dimension"/>
        <attr name="gaugeTrackColor" format="color"/>
        <attr name="gaugeLevelColor" format="color"/>
        <attr name="gaugeWarningColor" format="color"/>
        <attr name="gaugeAlertColor" format="color"/>
        <attr name="gaugeTitle" format="string"/>
        <attr name="gaugeTitleColor" format="color"/>
        <attr name="gaugeTitleTextSize" format="dimension"/>
        <attr name="gaugeStatusText" format="string"/>
        <attr name="gaugeStatusColor" format="color"/>
        <attr name="gaugeStatusTextSize" format="dimension"/>
        <attr name="gaugeShowShadow" format="boolean"/>
        <!-- Screen-reader template for the current level, e.g. "Battery at %1$d percent" -->
        <attr name="gaugeLevelDescription" format="string"/>
    </declare-styleable>

    <declare-styleable name="BatteryRangeSliderPreference">
        <!-- SharedPreferences keys the two thumbs persist to -->
        <attr name="criticalKey" format="string"/>
        <attr name="warningKey" format="string"/>
        <!-- Combined track bounds and the minimum gap kept between the two thumbs -->
        <attr name="sliderFrom" format="integer"/>
        <attr name="sliderTo" format="integer"/>
        <attr name="sliderMinSeparation" format="integer"/>
        <attr name="criticalDefault" format="integer"/>
        <attr name="warningDefault" format="integer"/>
    </declare-styleable>
</resources>